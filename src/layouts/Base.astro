---
// src/layout/Base.astro
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import ChantPlayer from '../components/ChantPlayer.astro'
const { title, description, image } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const gaConsentStorageKey = 'ga_consent_choice';
const currentPathname = Astro.url.pathname;
const baseSegment = baseUrl.replace(/^\/+|\/+$/g, '');
const pathSegments = currentPathname.split('/').filter(Boolean);
const relativeSegments = baseSegment && pathSegments[0] === baseSegment
    ? pathSegments.slice(1)
    : pathSegments;
const relativePath = relativeSegments.join('/');
const showBreadcrumbs = relativePath.length > 0;
const metaDescription = description || 'Uma curadoria de artigos, livros e recursos para aprofundar sua fé e conhecimento.';
const pageTitle = title ? `${title} - Katholikos` : 'Katholikos - Artigos, Livros e Recursos';
const canonicalUrl = Astro.url.href;
const fallbackImagePath = `${baseUrl}assets/cover-example.jpg`;
const ogImageUrl = new URL(image || fallbackImagePath, Astro.url).href;
---
<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>
        <meta name="description" content={metaDescription} />
        <link rel="canonical" href={canonicalUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Katholikos" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={metaDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImageUrl} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={metaDescription} />
        <meta name="twitter:image" content={ogImageUrl} />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
        {gaMeasurementId && (
            <>
                <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
                <script define:vars={{ gaMeasurementId, gaConsentStorageKey }}>
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    window.gtag = gtag;

                    gtag('js', new Date());
                    gtag('consent', 'default', {
                        analytics_storage: 'denied',
                        ad_storage: 'denied',
                        ad_user_data: 'denied',
                        ad_personalization: 'denied',
                        wait_for_update: 500,
                    });

                    const savedConsent = localStorage.getItem(gaConsentStorageKey);
                    if (savedConsent === 'accepted') {
                        gtag('consent', 'update', {
                            analytics_storage: 'granted',
                            ad_storage: 'denied',
                            ad_user_data: 'denied',
                            ad_personalization: 'denied',
                        });
                        gtag('config', gaMeasurementId);
                    }
                </script>
            </>
        )}
    </head>
    <body class="bg-black text-white">
        <Navbar />
        <main class="max-w-6xl mx-auto px-6 py-8">
            {showBreadcrumbs && <Breadcrumbs path={relativePath} baseUrl={baseUrl} currentTitle={title} />}
            <slot />
        </main>
        <Footer />
        <ChantPlayer />

        {gaMeasurementId && (
            <div
                id="ga-consent-banner"
                class="hidden fixed bottom-4 left-4 right-4 md:left-auto md:max-w-md bg-gray-900 border border-gray-700 rounded-lg p-4 shadow-lg z-50"
                role="dialog"
                aria-label="Preferências de cookies"
            >
                <p class="text-sm text-gray-300 mb-3">
                    Usamos cookies de análise para entender como o site é utilizado e melhorar sua experiência.
                </p>
                <div class="flex gap-2 justify-end">
                    <button id="ga-consent-reject" class="px-3 py-2 text-sm rounded-md border border-gray-700 text-gray-300 hover:text-white hover:border-gray-500 transition">
                        Recusar
                    </button>
                    <button id="ga-consent-accept" class="px-3 py-2 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 transition">
                        Aceitar
                    </button>
                </div>
            </div>
        )}

        {gaMeasurementId && (
            <script define:vars={{ gaMeasurementId, gaConsentStorageKey }}>
                const banner = document.getElementById('ga-consent-banner');
                const acceptButton = document.getElementById('ga-consent-accept');
                const rejectButton = document.getElementById('ga-consent-reject');

                const hideBanner = () => {
                    banner?.classList.add('hidden');
                };

                const showBanner = () => {
                    banner?.classList.remove('hidden');
                };

                const savedConsent = localStorage.getItem(gaConsentStorageKey);
                if (!savedConsent) {
                    showBanner();
                }

                acceptButton?.addEventListener('click', () => {
                    localStorage.setItem(gaConsentStorageKey, 'accepted');
                    if (window.gtag) {
                        window.gtag('consent', 'update', {
                            analytics_storage: 'granted',
                            ad_storage: 'denied',
                            ad_user_data: 'denied',
                            ad_personalization: 'denied',
                        });
                        window.gtag('config', gaMeasurementId);
                    }
                    hideBanner();
                });

                rejectButton?.addEventListener('click', () => {
                    localStorage.setItem(gaConsentStorageKey, 'rejected');
                    if (window.gtag) {
                        window.gtag('consent', 'update', {
                            analytics_storage: 'denied',
                            ad_storage: 'denied',
                            ad_user_data: 'denied',
                            ad_personalization: 'denied',
                        });
                    }
                    hideBanner();
                });
            </script>
        )}
    </body>
</html>