---
// src/components/Navbar.astro
import SearchBar from './SearchBar.astro';
const base = import.meta.env.BASE_URL;
---
<nav class="bg-gray-900 border-b border-gray-800">
    <div class="max-w-6xl mx-auto px-6 py-4">
        <div class="flex justify-between items-center">
            <a href={base} class="text-2xl font-serif font-bold text-white">
                Katholikos
            </a>

            <div class="flex items-center gap-2">
                <div class="hidden md:flex gap-8 items-center">
                    <a href={`${base}artigos`} class="text-sm font-medium text-gray-300 hover:text-white transition">
                        Artigos
                    </a>
                    <a href={`${base}categorias`} class="text-sm font-medium text-gray-300 hover:text-white transition">
                        Categorias
                    </a>
                    <a href={`${base}livros`} class="text-sm font-medium text-gray-300 hover:text-white transition">
                        Livros
                    </a>
                    <a href={`${base}santos`} class="text-sm font-medium text-gray-300 hover:text-white transition">
                        Santos
                    </a>
                    <a href={`${base}missao`} class="text-sm font-medium text-gray-300 hover:text-white transition">
                        Missão
                    </a>
                    <button class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
                        Inscrever-se
                    </button>
                </div>

                <SearchBar />

                <button
                    id="mobileMenuButton"
                    class="md:hidden text-gray-300 hover:text-white transition p-2"
                    aria-label="Abrir menu de navegação"
                    aria-controls="mobileMenuPanel"
                    aria-expanded="false"
                >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <div id="mobileMenuPanel" class="hidden md:hidden mt-4 border-t border-gray-800 pt-4">
            <div class="flex flex-col gap-3">
                <a href={`${base}artigos`} class="text-sm font-medium text-gray-300 hover:text-white transition">Artigos</a>
                <a href={`${base}categorias`} class="text-sm font-medium text-gray-300 hover:text-white transition">Categorias</a>
                <a href={`${base}livros`} class="text-sm font-medium text-gray-300 hover:text-white transition">Livros</a>
                <a href={`${base}santos`} class="text-sm font-medium text-gray-300 hover:text-white transition">Santos</a>
                <a href={`${base}missao`} class="text-sm font-medium text-gray-300 hover:text-white transition">Missão</a>
                <button class="mt-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition w-full">
                    Inscrever-se
                </button>
            </div>
        </div>
    </div>
</nav>

<script>
    const mobileMenuButton = document.getElementById('mobileMenuButton');
    const mobileMenuPanel = document.getElementById('mobileMenuPanel');

    const closeMobileMenu = () => {
        if (!mobileMenuButton || !mobileMenuPanel) return;
        mobileMenuPanel.classList.add('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
    };

    mobileMenuButton?.addEventListener('click', () => {
        if (!mobileMenuPanel) return;
        const isOpen = !mobileMenuPanel.classList.contains('hidden');
        mobileMenuPanel.classList.toggle('hidden', isOpen);
        mobileMenuButton.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeMobileMenu();
        }
    });

    mobileMenuPanel?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
            closeMobileMenu();
        });
    });
</script>
