---
const baseUrl = import.meta.env.BASE_URL;

const presetTracks = [
    {
        label: 'Salve Regina',
        url: 'https://commons.wikimedia.org/wiki/Special:FilePath/Petits_Chanteurs_de_Passy_-_Salve_Regina_de_Hermann_Contract.ogg',
    },
    {
        label: 'Ave Maria',
        url: 'https://commons.wikimedia.org/wiki/Special:FilePath/Schola_Gregoriana-Ave_Maria.ogg',
    },
    {
        label: 'Kyrie Eleison',
        url: 'https://commons.wikimedia.org/wiki/Special:FilePath/Schola_Gregoriana-Kyrie_eleison.ogg',
    },
];

const defaultAudioUrl = presetTracks[0].url || `${baseUrl}assets/audio/salve-regina.mp3`;
---

<section class="fixed bottom-3 right-3 z-50 w-[calc(100vw-1.5rem)] max-w-72 rounded-lg border border-gray-700 bg-gray-900/95 p-2.5 sm:bottom-4 sm:right-4 sm:w-72 sm:p-3 shadow-lg backdrop-blur">
    <p class="mb-1.5 text-[11px] sm:text-xs font-semibold uppercase tracking-wider text-blue-400">Canto Gregoriano</p>
    <div class="mb-1.5 sm:mb-2">
        <select id="chant-preset" aria-label="Seleção de canto gregoriano" class="w-full rounded-md border border-gray-700 bg-gray-950 px-2 py-1.5 sm:py-2 text-xs sm:text-sm text-gray-100 focus:border-blue-500 focus:outline-none">
            {presetTracks.map((track) => (
                <option value={track.url}>{track.label}</option>
            ))}
        </select>
    </div>
    <div class="mb-1.5 sm:mb-2">
        <div class="mb-1 flex items-center justify-between">
            <label for="chant-volume" class="block text-[11px] sm:text-xs text-gray-400">Volume</label>
            <span id="chant-volume-value" class="text-[11px] sm:text-xs text-gray-400">60%</span>
        </div>
        <input
            id="chant-volume"
            type="range"
            min="0"
            max="1"
            step="0.01"
            value="0.6"
            class="w-full accent-blue-500"
        />
    </div>
    <div class="flex items-center gap-1.5 sm:gap-2">
        <button id="chant-mute" type="button" class="rounded-md border border-gray-700 px-2.5 py-1.5 sm:px-3 sm:py-2 text-xs sm:text-sm text-gray-100 hover:border-blue-500 hover:text-blue-300 transition">
            Silenciar
        </button>
        <button id="chant-toggle" type="button" class="rounded-md border border-gray-700 px-2.5 py-1.5 sm:px-3 sm:py-2 text-xs sm:text-sm text-gray-100 hover:border-blue-500 hover:text-blue-300 transition">
            Tocar
        </button>
    </div>
    <p id="chant-status" class="mt-1.5 sm:mt-2 text-[11px] sm:text-xs text-gray-400"></p>
    <audio id="chant-audio" preload="none" loop class="hidden"></audio>
</section>

<script define:vars={{ defaultAudioUrl, presetTracks }}>
    const presetSelect = document.getElementById('chant-preset');
    const volumeInput = document.getElementById('chant-volume');
    const volumeValue = document.getElementById('chant-volume-value');
    const muteButton = document.getElementById('chant-mute');
    const toggle = document.getElementById('chant-toggle');
    const audio = document.getElementById('chant-audio');
    const status = document.getElementById('chant-status');

    const trackKey = 'chant_track_url';
    const enabledKey = 'chant_enabled';
    const volumeKey = 'chant_volume';
    const mutedKey = 'chant_muted';

    const setStatus = (message, tone = 'neutral') => {
        if (!status) return;
        status.textContent = message;
        status.classList.remove('text-gray-400', 'text-red-300', 'text-green-300');
        if (tone === 'error') status.classList.add('text-red-300');
        else if (tone === 'ok') status.classList.add('text-green-300');
        else status.classList.add('text-gray-400');
    };

    const updateButton = () => {
        if (!toggle || !audio) return;
        toggle.textContent = audio.paused ? 'Tocar' : 'Pausar';
    };

    const updateMuteButton = () => {
        if (!muteButton || !audio) return;
        muteButton.textContent = audio.muted ? 'Ativar som' : 'Silenciar';
    };

    const setSource = (src) => {
        if (!audio || !src) return;
        if (audio.src !== src) {
            audio.src = src;
            audio.load();
        }
    };

    const normalizeUrl = (value) => (value || '').trim();

    const normalizeVolume = (value) => {
        const parsed = Number(value);
        if (Number.isNaN(parsed)) return 0.6;
        return Math.max(0, Math.min(1, parsed));
    };

    const updateVolumeUI = (value) => {
        if (volumeInput) {
            volumeInput.value = String(value);
        }
        if (volumeValue) {
            volumeValue.textContent = `${Math.round(value * 100)}%`;
        }
    };

    const savedTrack = normalizeUrl(localStorage.getItem(trackKey));
    const initialTrack = savedTrack || defaultAudioUrl;

    if (initialTrack) {
        setSource(initialTrack);
        setStatus('Escolha uma opção pronta e clique em Tocar.');
    }

    const savedVolume = normalizeVolume(localStorage.getItem(volumeKey));
    if (audio) {
        audio.volume = savedVolume;
        audio.muted = localStorage.getItem(mutedKey) === 'true';
    }
    updateVolumeUI(savedVolume);
    updateMuteButton();

    if (presetSelect) {
        const matchedPreset = presetTracks.find((track) => track.url === initialTrack) || presetTracks[0];
        if (matchedPreset) {
            presetSelect.value = matchedPreset.url;
        }
    }

    const shouldPlay = localStorage.getItem(enabledKey) === 'true';

    volumeInput?.addEventListener('input', () => {
        const currentVolume = normalizeVolume(volumeInput.value);
        if (audio) {
            audio.volume = currentVolume;
        }
        localStorage.setItem(volumeKey, String(currentVolume));
        updateVolumeUI(currentVolume);
    });

    muteButton?.addEventListener('click', () => {
        if (!audio) return;
        audio.muted = !audio.muted;
        localStorage.setItem(mutedKey, String(audio.muted));
        updateMuteButton();
    });

    if (shouldPlay && audio) {
        audio.play().catch(() => {
            localStorage.setItem(enabledKey, 'false');
            setStatus('Clique em Tocar para iniciar o canto.', 'neutral');
            updateButton();
        });
    }

    presetSelect?.addEventListener('change', () => {
        const src = normalizeUrl(presetSelect.value);
        if (!src) return;
        localStorage.setItem(trackKey, src);
        setSource(src);
        setStatus('Opção pronta selecionada. Clique em Tocar.');
    });

    const ensureSource = () => {
        const src = normalizeUrl(presetSelect?.value) || normalizeUrl(localStorage.getItem(trackKey)) || defaultAudioUrl;
        if (!src) {
            setStatus('Selecione uma opção de áudio antes de tocar.', 'error');
            return null;
        }
        setSource(src);
        return src;
    };

    const maybeAutoplaySaved = async () => {
        const src = ensureSource();
        if (!src) return;
        if (localStorage.getItem(enabledKey) === 'true' && audio) {
            try {
                await audio.play();
                setStatus('Reproduzindo.', 'ok');
            } catch {
                localStorage.setItem(enabledKey, 'false');
                setStatus('Não foi possível reproduzir este arquivo.', 'error');
            }
            updateButton();
        }
    };

    maybeAutoplaySaved();

    toggle?.addEventListener('click', async () => {
        if (!audio) return;

        if (audio.paused) {
            const src = ensureSource();
            if (!src) return;
            try {
                await audio.play();
                localStorage.setItem(enabledKey, 'true');
                setStatus('Reproduzindo.', 'ok');
            } catch {
                localStorage.setItem(enabledKey, 'false');
                setStatus('Navegador bloqueou ou arquivo não encontrado.', 'error');
            }
        } else {
            audio.pause();
            localStorage.setItem(enabledKey, 'false');
            setStatus('Pausado.');
        }

        updateButton();
    });

    audio?.addEventListener('play', updateButton);
    audio?.addEventListener('pause', updateButton);
    audio?.addEventListener('volumechange', updateMuteButton);
    audio?.addEventListener('error', () => {
        localStorage.setItem(enabledKey, 'false');
        setStatus('Falha ao carregar a URL de áudio.', 'error');
        updateButton();
    });

    updateButton();
    updateMuteButton();
</script>
