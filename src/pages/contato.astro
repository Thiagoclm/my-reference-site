---
import Layout from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';

const base = import.meta.env.BASE_URL;
const pageDescription = 'Entre em contato com O Católico Cientista. Nosso email oficial ainda está em definição.';
const contactEmailStatus = 'Em definição';
---

<Layout title="Contato" description={pageDescription}>
    <Hero 
        title="Contato"
        subtitle="Fale conosco para dúvidas, sugestões e parcerias."
        image={`${base}assets/cover-example.jpg`}
    />

    <div class="max-w-3xl mx-auto">
        <section class="bg-gray-900 border border-gray-800 rounded-xl p-8 md:p-10 mb-8">
            <h2 class="text-2xl font-serif font-bold text-white mb-4">Canal de email</h2>
            <p class="text-gray-300 leading-relaxed mb-4">
                Nosso email de contato oficial ainda não foi publicado.
            </p>
            <p class="text-gray-300 leading-relaxed">
                Status atual: <span class="text-blue-400 font-semibold">{contactEmailStatus}</span>
            </p>
        </section>

        <section class="bg-gray-900 border border-gray-800 rounded-xl p-8 md:p-10">
            <h2 class="text-2xl font-serif font-bold text-white mb-4">Enquanto isso</h2>
            <ul class="list-disc pl-6 text-gray-300 space-y-2">
                <li>Use o formulário de inscrição para receber atualizações.</li>
                <li>Acompanhe as publicações para próximos anúncios de contato.</li>
            </ul>
        </section>
    </div>
</Layout>
