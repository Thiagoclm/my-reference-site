---
import Layout from '../../layouts/Base.astro';
import { scientists } from '../../data/scientists';

const base = import.meta.env.BASE_URL;
const pageDescription = 'Perfis de cientistas católicos e pioneiros que contribuíram para a ciência e para a educação.';
const uniqueTags = [...new Set(scientists.flatMap((scientist) => scientist.tags))].sort((a, b) => a.localeCompare(b));
---

<Layout title="Cientistas — Perfis e Legado" description={pageDescription}>
    <div class="max-w-6xl mx-auto">
        <div class="mb-12">
            <div class="inline-block mb-6">
                <h2 class="text-sm font-bold text-blue-400 uppercase tracking-wider">Publicações</h2>
            </div>
            <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">Cientistas</h1>
            <p class="text-xl text-gray-300 max-w-3xl">
                Perfis de cientistas católicos e pioneiros da pesquisa, com foco em suas contribuições acadêmicas, humanas e espirituais.
            </p>
        </div>

        <section class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
                <h2 class="text-lg font-bold text-white">Filtrar por Tags</h2>
                <p id="scientist-filter-count" class="text-sm text-gray-400">Mostrando {scientists.length} de {scientists.length}</p>
            </div>
            <div class="flex flex-wrap gap-2" id="scientist-filters">
                <button
                    type="button"
                    class="scientist-filter-btn bg-blue-600 text-white px-3 py-1.5 rounded-full text-sm font-semibold"
                    data-tag="all"
                    aria-pressed="true"
                >
                    Todos
                </button>
                {uniqueTags.map((tag) => (
                    <button
                        type="button"
                        class="scientist-filter-btn bg-gray-800 text-gray-300 px-3 py-1.5 rounded-full text-sm font-semibold hover:bg-gray-700 transition"
                        data-tag={tag.toLowerCase()}
                        aria-pressed="false"
                    >
                        {tag}
                    </button>
                ))}
            </div>
        </section>

        <div class="space-y-8 mb-16" id="scientist-list">
            {scientists.map((scientist) => (
                <article
                    class="scientist-item bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-gray-700 transition group"
                    data-tags={scientist.tags.map((tag) => tag.toLowerCase()).join('|')}
                >
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-0">
                        <div class="md:col-span-1">
                            {scientist.link ? (
                                <a href={`${base}${scientist.link}`}>
                                    <img
                                        src={`${base}${scientist.image}`}
                                        alt={scientist.name}
                                        class="w-full h-64 md:h-full object-cover group-hover:scale-105 transition duration-500"
                                    />
                                </a>
                            ) : (
                                <img
                                    src={`${base}${scientist.image}`}
                                    alt={scientist.name}
                                    class="w-full h-64 md:h-full object-cover"
                                />
                            )}
                        </div>

                        <div class="md:col-span-3 p-6 md:p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex flex-wrap gap-2 mb-4">
                                    {scientist.tags.map((tag) => (
                                        <span class="bg-blue-900 text-blue-300 text-xs font-semibold px-3 py-1 rounded-full">
                                            {tag}
                                        </span>
                                    ))}
                                </div>

                                {scientist.link ? (
                                    <a href={`${base}${scientist.link}`} class="block">
                                        <h2 class="text-2xl md:text-3xl font-serif font-bold text-white mb-2 group-hover:text-blue-400 transition">
                                            {scientist.name}
                                        </h2>
                                    </a>
                                ) : (
                                    <h2 class="text-2xl md:text-3xl font-serif font-bold text-white mb-2">
                                        {scientist.name}
                                    </h2>
                                )}
                                <p class="text-gray-400 font-serif italic mb-4">{scientist.subtitle}</p>

                                <p class="text-gray-300 leading-relaxed mb-6">
                                    {scientist.summary}
                                </p>
                            </div>

                            <div>
                                {scientist.link ? (
                                    <a
                                        href={`${base}${scientist.link}`}
                                        class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition text-sm"
                                    >
                                        Ler Perfil Completo →
                                    </a>
                                ) : (
                                    <span class="inline-block bg-gray-800 text-gray-300 px-6 py-3 rounded-lg font-semibold text-sm">
                                        Em breve
                                    </span>
                                )}
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
        <p id="no-scientist-results" class="hidden text-gray-400 text-center mb-12">Nenhum resultado encontrado para este filtro.</p>
    </div>
</Layout>

<script>
    const filterButtons = Array.from(document.querySelectorAll('.scientist-filter-btn'));
    const scientistItems = Array.from(document.querySelectorAll('.scientist-item'));
    const filterCount = document.getElementById('scientist-filter-count');
    const noResults = document.getElementById('no-scientist-results');

    const setActiveButton = (selectedTag) => {
        filterButtons.forEach((button) => {
            const isActive = button.getAttribute('data-tag') === selectedTag;
            button.setAttribute('aria-pressed', String(isActive));

            if (isActive) {
                button.classList.remove('bg-gray-800', 'text-gray-300', 'hover:bg-gray-700');
                button.classList.add('bg-blue-600', 'text-white');
                return;
            }

            button.classList.remove('bg-blue-600', 'text-white');
            button.classList.add('bg-gray-800', 'text-gray-300', 'hover:bg-gray-700');
        });
    };

    const applyFilter = (selectedTag) => {
        let visibleCount = 0;

        scientistItems.forEach((scientist) => {
            const tagList = (scientist.getAttribute('data-tags') || '').split('|').filter(Boolean);
            const shouldShow = selectedTag === 'all' || tagList.includes(selectedTag);

            scientist.classList.toggle('hidden', !shouldShow);
            if (shouldShow) visibleCount += 1;
        });

        if (filterCount) {
            filterCount.textContent = `Mostrando ${visibleCount} de ${scientistItems.length}`;
        }

        if (noResults) {
            noResults.classList.toggle('hidden', visibleCount !== 0);
        }
    };

    filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
            const selectedTag = button.getAttribute('data-tag') || 'all';
            setActiveButton(selectedTag);
            applyFilter(selectedTag);
        });
    });
</script>
